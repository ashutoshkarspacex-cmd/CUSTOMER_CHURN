        "\n",
        "fig = px.histogram(df, x=\"Churn\", color=\"Contract\", barmode=\"group\", title=\"<b><i>Churn Distribution w.r.t Contract<i><b>\", color_discrete_map = color_discrete_map)\n",
        "fig.update_layout(width=700, height=500, bargap=0.1)\n",
        "fig.show()"
      ]
