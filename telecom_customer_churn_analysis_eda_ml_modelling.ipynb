        "fig = px.histogram(df, x=\"Churn\", color=\"SeniorCitizen\", title=\"<b>Churn distribution w.r.t. Senior Citizen</b>\", color_discrete_map=color_map)\n",
        "fig.update_layout(width=700, height=500, bargap=0.1)\n",
        "fig.show()"
      ]
    },
